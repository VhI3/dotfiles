#!/bin/bash

# Define the configuration file path
CONFIG_FILE="/etc/X11/xorg.conf.d/00-keyboard.conf"

# Ensure the directory exists
sudo mkdir -p /etc/X11/xorg.conf.d/

# Write the new keyboard configuration
echo "Updating $CONFIG_FILE to swap Caps Lock and Escape..."

sudo bash -c "cat > $CONFIG_FILE" <<EOF
Section "InputClass"
    Identifier "system-keyboard"
    MatchIsKeyboard "on"
    Option "XkbLayout" "us,ir"
    Option "XkbVariant" "altgr-intl,"
    Option "XkbOptions" "grp:alt_shift_toggle,caps:swapescape"
EndSection
EOF

# Restart the display manager
echo "Restarting i3wm to apply changes..."
i3-msg restart

echo "Configuration applied! You may need to log out and log back in for changes to take effect."

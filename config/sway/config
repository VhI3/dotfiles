exec waybar
exec_always sh -lc 'pkill -f "$HOME/.local/bin/notify-layout" 2>/dev/null || true; exec "$HOME/.local/bin/notify-layout"'

input type:touchpad {
  tap enabled
  natural_scroll enabled
  dwt enabled
}


input * {
    xkb_layout us,ir
    xkb_options caps:swapescape,grp:alt_shift_toggle,compose:ralt
}

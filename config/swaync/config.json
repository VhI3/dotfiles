{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "layer-shell": true,
  "control-center-layer": "top",
  "control-center-positionX": "right",
  "control-center-positionY": "top",
  "fit-to-screen": false,
  "relative-timestamps": true,
  "timeout": 8,
  "timeout-low": 4,
  "timeout-critical": 0,
  "notification-window-width": 420,
  "control-center-width": 520,
  "control-center-height": 720,
  "notification-body-image-height": 96,
  "notification-body-image-width": 96,
  "widgets": [
    "title",
    "dnd",
    "notifications",
    "mpris",
    "volume",
    "backlight"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 80,
      "image-radius": 10
    },
    "volume": {
      "label": "Volume"
    },
    "backlight": {
      "label": "Brightness"
    }
  }
}
